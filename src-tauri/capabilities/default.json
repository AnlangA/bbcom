{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for bbcom",
  "windows": ["main", "ai-assistant"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-always-on-top",
    "core:window:allow-is-always-on-top",
    "dialog:default",
    "serialplugin:default",
    "store:default",
    "fs:default"
  ]
}
